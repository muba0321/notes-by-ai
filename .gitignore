# =============================================================================
# Git Ignore 文件 - OpenClaw Notes
# =============================================================================

# -----------------------------------------------------------------------------
# 敏感信息（包含密码、Token、密钥等）
# -----------------------------------------------------------------------------
**/ip-subagent.txt
**/passwords.txt
**/credentials.txt
**/*.pem
**/*.key
**/.env
**/secrets/

# -----------------------------------------------------------------------------
# 本地配置（不需要同步）
# -----------------------------------------------------------------------------
**/local.conf
**/local.config
**/*.local

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*~

# -----------------------------------------------------------------------------
# 系统文件
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 日志文件
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# 构建产物（如需要）
# -----------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
